# ==============================================
# E-GALLERY DEVELOPMENT ENVIRONMENT
# ==============================================
# Copy this file to .env.local for local development

# ==============================================
# APPLICATION SETTINGS
# ==============================================

NEXT_PUBLIC_URL=http://localhost:3000
NODE_ENV=development
DEBUG=true
LOG_LEVEL=debug

# ==============================================
# AUTHENTICATION
# ==============================================

# Generate with: openssl rand -base64 32
AUTH_SECRET=dev_auth_secret_change_me_in_production
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_TRUST_HOST=true

# ==============================================
# DATABASE (MySQL via Docker)
# ==============================================

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=egallery
DB_CONNECTION_LIMIT=10

# ==============================================
# EMAIL (Use your own SMTP or Gmail App Password)
# ==============================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
EMAIL_FROM="E-Gallery Dev" <egallery@gmail.com>

# ==============================================
# STRIPE (Use test mode keys)
# ==============================================

STRIPE_SECRET_KEY=sk_test_your_test_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==============================================
# ESEWA (Test environment)
# ==============================================

ESEWA_SECRET=your_esewa_test_secret
ESEWA_MERCHANT_ID=EPAYTEST

# ==============================================
# CLOUDINARY (Optional)
# ==============================================

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==============================================
# CORS
# ==============================================

ALLOWED_ORIGINS=http://localhost:3000

# ==============================================
# RATE LIMITING
# ==============================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=100

# ==============================================
# FILE UPLOADS
# ==============================================

MAX_FILE_SIZE=10485760
UPLOAD_DIR=public/uploads

# ==============================================
# CACHE
# ==============================================

CACHE_ENABLED=true
CACHE_TTL=3600