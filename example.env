
# ==============================================
# APPLICATION SETTINGS
# ==============================================

NEXT_PUBLIC_URL=http://localhost:3000/



# Application Secret Key (generate a secure random string)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_key
AUTH_SALT_ROUNDS = no_of_salt_rounds

NEXTAUTH_URL=your_server_url


DATABASE_URL=you_postgres_db_connection_string

# ==============================================
# EMAIL / SMTP CONFIGURATION
# ==============================================

SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password

# ==============================================
# STRIPE PAYMENT GATEWAY
# ==============================================


STRIPE_SECRET_KEY=your_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_secret_key
STRIPE_WEBHOOK_SECRET=your_secret_key

# ==============================================
# ESEWA PAYMENT GATEWAY (Nepal)
# ==============================================

ESEWA_SECRET=esewa_secret


# ==============================================
# CLOUDINARY 
# ==============================================

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_secret_key
CLOUDINARY_API_SECRET=your_secret_key


ALLOWED_ORIGINS=your_allowed_origins



# ==============================================
# FILE UPLOAD SETTINGS
# ==============================================

MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif
